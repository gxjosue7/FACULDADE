class Funcionario:
    def __init__(self, nome, salario):
        self.nome = nome
        self.salario = salario

    def obterNome(self):
        return self.nome

    def obterSalario(self):
        return self.salario

    def aumentarSalario(self, percentual):
        self.salario += self.salario * percentual / 100


f = Funcionario("Harry", 25000)
print(f"Nome: {f.obterNome()} | Salário: R$ {f.obterSalario():.2f}")
f.aumentarSalario(10)
print(f"Novo salário: R$ {f.obterSalario():.2f}")